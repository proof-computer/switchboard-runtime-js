{
  "name": "@proof-computer/switchboard-runtime",
  "version": "0.1.0",
  "description": "Job-side runtime helpers for Switchboard Acurast webserver jobs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proof-computer/switchboard-runtime-js.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gateway-upstream-admission": {
      "types": "./dist/gateway-upstream-admission.d.ts",
      "import": "./dist/gateway-upstream-admission.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepare": "npm run build",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "dependencies": {
    "acme-client": "^5.4.0",
    "ethers": "^6.15.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  }
}
